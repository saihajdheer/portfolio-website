    }

    try {
      videoStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: { ideal: 400 }, height: { ideal: 400 } } });
      videoEl.srcObject = videoStream;
      lensInner.classList.add('active');
    } catch (err) {
      console.error("Error accessing camera: ", err);
      if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
        alert("Camera Permission Denied! You previously blocked the camera for this website. Click the little lock/camera icon next to the URL bar at the top of your browser to allow access, then refresh the page.");
      } else {
        alert("Could not access camera. Error: " + err.message);
      }
    }
  }

  async function takePhoto() {
    if (window.location.protocol === 'file:') {
      alert("Camera Blocked:\nFor security reasons, your browser has blocked the webcam because you opened the HTML file directly on your PC.\n\nTo make it work, please open this file through 'Live Server' in VS Code.");
      return;
    }
    if (!videoStream) {
      // Start the camera for them if they just push the shutter
      await startCamera();
      if (!videoStream) return; // If permission denied or failed
      // Wait a moment for stream to settle before snapping photo
      await new Promise(r => setTimeout(r, 600));
    }
    
    // Flash effect
    flashEffect.classList.add('flash');
    setTimeout(() => { flashEffect.classList.remove('flash'); }, 100);
    
    // Draw video frame to canvas
    const ctx = canvasEl.getContext('2d');
    
    // Reverse the mirror effect for drawing (so image looks like what they saw)
    ctx.translate(canvasEl.width, 0);
    ctx.scale(-1, 1);
    
    const vWidth = videoEl.videoWidth || 400; // Fallback to 400 if 0
    const vHeight = videoEl.videoHeight || 400;
    let minDim = Math.min(vWidth, vHeight);
    if (minDim === 0) minDim = 400; // Prevent crash if still 0
    
    const startX = (vWidth - minDim) / 2;
    const startY = (vHeight - minDim) / 2;
    
    try {
      ctx.drawImage(videoEl, startX, startY, minDim, minDim, 0, 0, canvasEl.width, canvasEl.height);
    } catch (e) {
      console.error("Error drawing image:", e);
      // Let it continue so we at least print a black polaroid
    }
    
    // Reset transform just in case
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    
    const dataUrl = canvasEl.toDataURL('image/jpeg', 0.9);
    
    // Create new polaroid element
    const newPol = document.createElement('div');
    newPol.className = 'pol printed-pol bg-doodle';
    
    // Add randomness to final rotation
    const rotation = (Math.random() * 30) - 15;
    // Set custom prop for animation final state
    newPol.style.setProperty('--print-rot', rotation + 'deg');
    
    // Store it so dragging works natively via data-b
    newPol.setAttribute('data-b', rotation);
    
    newPol.innerHTML = \`
      <div class="pol-img" style="overflow: hidden;">
        <img src="\${dataUrl}" alt="My Polaroid" style="width:100%; height:100%; object-fit:cover;" draggable="false" />
      </div>
      <span class="pol-lbl">Guest</span>
      <span class="pol-sub">Just now</span>
    \`;
    
    // Insert into DOM
    document.getElementById('cameraContainer').appendChild(newPol);
    
    // Trigger animation after brief delay
    setTimeout(() => {
      newPol.classList.add('anim-print');
      
      // Make draggable after animation finishes
      setTimeout(() => {
        newPol.style.animation = 'none';
        newPol.style.transform = \`translateX(-50%) translateY(-260px) rotate(\${rotation}deg)\`;
        makeDraggable(newPol);
      }, 2500);
    }, 100);
  }
</script>
