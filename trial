<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&family=Caveat:wght@400;700&display=swap"
    rel="stylesheet">
  <title>Saihaj Dheer â€” UI/UX Designer</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #fdf9f6;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, rgba(160, 145, 130, 0.32) 1.2px, transparent 1.2px);
      background-size: 28px 28px;
      mask-image: radial-gradient(ellipse 85% 85% at 50% 50%, black 10%, transparent 100%);
      -webkit-mask-image: radial-gradient(ellipse 85% 85% at 50% 50%, black 10%, transparent 100%);
      pointer-events: none;
      z-index: 0;
    }

    /* SPLASH */
    #splash {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: opacity .7s;
    }

    #splash.out {
      opacity: 0;
      pointer-events: none;
    }

    .name-row {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      justify-content: center;
      gap: 2px;
      position: relative;
      z-index: 1;
    }

    .letter {
      font-size: clamp(44px, 8vw, 88px);
      font-weight: 900;
      color: #1a1a1a;
      opacity: 0;
      transform: translateY(18px);
      transition: opacity .45s ease, transform .45s ease;
      letter-spacing: -3px;
      line-height: 1;
    }

    .letter.show {
      opacity: 1;
      transform: translateY(0);
    }

    .letter.pk {
      color: #e8587a;
    }

    .sp-gap {
      width: clamp(10px, 2vw, 22px);
    }

    #usvg {
      display: block;
      margin-top: -4px;
      opacity: 0;
      transition: opacity .3s;
      position: relative;
      z-index: 1;
      max-width: 90vw;
    }

    #usvg.vis {
      opacity: 1;
    }

    #upath {
      stroke-dasharray: 560;
      stroke-dashoffset: 560;
    }

    .splash-sub {
      font-family: 'Caveat', cursive;
      font-size: 18px;
      color: #aaa;
      margin-top: 14px;
      letter-spacing: 2px;
      opacity: 0;
      transform: translateY(6px);
      transition: opacity .5s, transform .5s;
      position: relative;
      z-index: 1;
    }

    .splash-sub.show {
      opacity: 1;
      transform: translateY(0);
    }

    #main {
      display: none;
      position: relative;
      z-index: 1;
    }

    /* NAV */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 52px;
      border-bottom: 1px solid rgba(180, 165, 150, 0.2);
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(253, 249, 246, 0.93);
      backdrop-filter: blur(10px);
    }

    .logo-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      cursor: pointer;
    }

    .logo-wrap img {
      height: 48px;
      width: auto;
      object-fit: contain;
    }

    .logo-name {
      font-family: 'Caveat', cursive;
      font-size: 17px;
      color: #555;
      letter-spacing: 1px;
      font-weight: 700;
    }

    .navlinks {
      display: flex;
      gap: 32px;
      list-style: none;
    }

    .navlinks a {
      text-decoration: none;
      font-size: 13px;
      color: #888;
      transition: color .2s;
      cursor: pointer;
      background: none;
      border: none;
      font-family: 'Inter', sans-serif;
    }

    .navlinks a:hover {
      color: #1a1a1a;
    }

    .navbtn {
      background: #e8587a;
      color: #fff;
      border: none;
      padding: 10px 22px;
      border-radius: 50px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: background .2s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .navbtn:hover {
      background: #c9385e;
    }

    /* HERO */
    #home {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px 24px 30px;
      min-height: 680px;
    }

    .hero-title {
      text-align: center;
      position: relative;
      z-index: 2;
      margin-bottom: 10px;
    }

    .hero-title .sub {
      font-family: 'Caveat', cursive;
      font-size: 17px;
      color: #bbb;
      display: block;
      margin-bottom: 6px;
    }

    .hero-title h1 {
      font-size: clamp(20px, 3vw, 38px);
      font-weight: 900;
      color: #1a1a1a;
      letter-spacing: -1.5px;
      line-height: 1.15;
    }

    .hero-title h1 .pk {
      color: #e8587a;
    }

    .scene {
      position: relative;
      width: 100%;
      max-width: 1080px;
      height: 540px;
      z-index: 2;
      margin: 0 auto;
    }

    .center-photo {
      position: absolute;
      left: 50%;
      bottom: 0;
      transform: translateX(-50%);
      width: 260px;
      height: auto;
      z-index: 10;
      cursor: pointer;
      transition: transform .3s;
    }

    .center-photo:hover {
      transform: translateX(-50%) scale(1.04) translateY(-6px);
    }

    .center-photo img {
      width: 100%;
      height: auto;
      display: block;
    }

    .photo-hint {
      display: none;
    }

    .pol {
      position: absolute;
      background: #fff;
      padding: 8px 8px 28px;
      border-radius: 3px;
      box-shadow: 0 3px 16px rgba(0, 0, 0, .09);
      cursor: grab;
      user-select: none;
      z-index: 5;
      width: 122px;
      transition: box-shadow .2s;
    }

    .pol:hover {
      box-shadow: 0 10px 30px rgba(0, 0, 0, .15);
      z-index: 15;
    }

    .pol:active {
      cursor: grabbing;
    }

    .pol-img {
      width: 100%;
      height: 84px;
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 30px;
    }

    .pol-lbl {
      font-family: 'Caveat', cursive;
      font-size: 13px;
      font-weight: 700;
      color: #333;
      text-align: center;
      display: block;
      margin-top: 4px;
    }

    .pol-sub {
      font-family: 'Caveat', cursive;
      font-size: 10px;
      color: #bbb;
      text-align: center;
      display: block;
    }

    @keyframes sw {

      0%,
      100% {
        transform: rotate(var(--r));
      }

      50% {
        transform: rotate(calc(var(--r)+2deg)) translateY(-4px);
      }
    }

    .sa {
      animation: sw 3.2s ease-in-out infinite;
    }

    .sb {
      animation: sw 3.8s ease-in-out infinite reverse;
    }

    .sc {
      animation: sw 2.9s ease-in-out infinite .4s;
    }

    .bg-swim {
      background: #dbeafe;
    }

    .bg-coffee {
      background: #fef9c3;
    }

    .bg-travel {
      background: #d1fae5;
    }

    .bg-food {
      background: #fce7f3;
    }

    .bg-doodle {
      background: #ede9fe;
    }

    .bg-sky {
      background: #e0f2fe;
    }

    .bg-shop {
      background: #fce7f3;
    }

    .bg-uxd {
      background: #d1fae5;
    }

    /* PROJECTS */
    #projects {
      padding: 80px 52px 160px;
      border-top: 1px solid rgba(180, 165, 150, 0.12);
    }

    .projects-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 860px;
      margin: 0 auto 52px;
    }

    .projects-header-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .proj-icon {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      background: #f5f0ea;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      border: 1px solid rgba(180, 165, 150, 0.2);
    }

    .proj-title {
      font-size: 24px;
      font-weight: 900;
      color: #1a1a1a;
      letter-spacing: -0.5px;
    }

    .proj-sub {
      font-size: 13px;
      color: #aaa;
      margin-top: 2px;
      font-style: italic;
    }

    .see-all-btn {
      background: #1a1a1a;
      color: #fff;
      border: none;
      padding: 12px 26px;
      border-radius: 50px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: background .2s;
    }

    .see-all-btn:hover {
      background: #333;
    }

    .stack-container {
      display: flex;
      flex-direction: column;
      gap: 40px;
      max-width: 920px;
      margin: 0 auto;
      padding-bottom: 120px;
    }

    .scard {
      position: sticky;
      height: 480px;
      border-radius: 28px;
      display: flex;
      overflow: hidden;
      box-shadow: 0 -8px 40px rgba(0, 0, 0, 0.08); /* shadow upwards helps stacking effect */
      border: 1px solid rgba(180, 165, 150, 0.2);
      transform-origin: top center;
      transition: filter 0.3s ease;
      cursor: pointer;
    }
    
    .scard:nth-child(1) { top: 120px; }
    .scard:nth-child(2) { top: 150px; }
    .scard:nth-child(3) { top: 180px; }

    .scard-img-side {
      width: 55%;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .scard-img-side img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .scard:hover .scard-img-side img {
      transform: scale(1.03);
    }

    .scard-content {
      width: 45%;
      background: #fff;
      padding: 56px 48px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .scard:nth-child(1) .scard-img-side { background: #dbeafe; }
    .scard:nth-child(2) .scard-img-side { background: #fce7f3; }
    .scard:nth-child(3) .scard-img-side { background: #dcfce7; }

    .scard-cat {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 12px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .scard-cat-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .scard:nth-child(1) .scard-cat-dot { background: #3b82f6; } /* UI/UX Blue */
    .scard:nth-child(2) .scard-cat-dot { background: #ec4899; } /* UI/UX Pink */
    .scard:nth-child(3) .scard-cat-dot { background: #22c55e; } /* Visual Green */

    .scard-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(28px, 3vw, 36px);
      font-weight: 900;
      color: #0b1a40;
      letter-spacing: -1px;
      line-height: 1.15;
      margin-bottom: 24px;
    }

    .scard-stats {
      font-size: 14px;
      color: #666;
      line-height: 1.6;
      margin-bottom: 36px;
    }

    .scard-stats p {
      margin-bottom: 6px;
    }

    .view-btn {
      background: #0a1128;
      color: #fff;
      border: none;
      padding: 14px 26px;
      border-radius: 50px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: background .2s, transform .2s;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: fit-content;
      text-decoration: none;
    }

    .view-btn:hover {
      background: #1c2b59;
      transform: translateY(-2px);
    }

    .view-btn svg {
      width: 20px;
      height: 20px;
    }

    /* ABOUT */
    #about {
      padding: 80px 52px 100px;
      border-top: 1px solid rgba(180, 165, 150, 0.12);
    }

    .about-inner {
      max-width: 980px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 70px;
      align-items: center;
    }

    .photo-card {
      background: #1a1a1a;
      border-radius: 24px;
      overflow: hidden;
      position: relative;
      transform: rotate(-3deg);
      box-shadow: 0 24px 64px rgba(0, 0, 0, .2);
      transition: transform .4s ease;
    }

    .photo-card:hover {
      transform: rotate(0deg) scale(1.02);
    }

    .photo-card .pc-img {
      width: 100%;
      aspect-ratio: .78;
      object-fit: cover;
      object-position: center top;
      display: block;
      filter: grayscale(15%);
    }

    .photo-card-footer {
      padding: 14px 18px 6px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .pc-name {
      font-size: 15px;
      font-weight: 600;
      color: #fff;
    }

    .pc-connect {
      background: #fff;
      color: #1a1a1a;
      border: none;
      border-radius: 50px;
      padding: 8px 16px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: background .2s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .pc-connect:hover {
      background: #e8f4ff;
    }

    .pc-linkedin {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 4px 18px 16px;
    }

    .pc-li-link {
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 7px;
      width: 100%;
    }

    .pc-li-dot {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: #e8587a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }

    .pc-li-txt {
      font-size: 11px;
      color: #888;
      transition: color .2s;
    }

    .pc-li-txt span {
      color: #bbb;
      font-weight: 500;
      transition: color .2s;
    }

    .pc-li-link:hover .pc-li-txt {
      color: #aaa;
    }

    .pc-li-link:hover .pc-li-txt span {
      color: #fff;
    }

    .about-big {
      font-size: clamp(26px, 3.2vw, 44px);
      font-weight: 800;
      color: #1a1a1a;
      line-height: 1.22;
      letter-spacing: -1.5px;
      margin-bottom: 32px;
    }

    .about-big .pk {
      color: #e8587a;
    }

    .mini-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: #f5f0ea;
      border-radius: 8px;
      padding: 3px 10px;
      font-size: 12px;
      vertical-align: middle;
      margin: 0 3px;
      border: 1px solid rgba(180, 165, 150, 0.28);
      font-family: 'Caveat', cursive;
      font-weight: 700;
      color: #555;
      white-space: nowrap;
    }

    .about-ctas {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .cta-res {
      background: transparent;
      color: #1a1a1a;
      border: 1.5px solid #ccc;
      padding: 12px 28px;
      border-radius: 50px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: border-color .2s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .cta-res:hover {
      border-color: #888;
    }

    .cta-abt {
      background: #1a1a1a;
      color: #fff;
      border: none;
      padding: 12px 28px;
      border-radius: 50px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: background .2s;
    }

    .cta-abt:hover {
      background: #333;
    }

    /* MODAL */
    .mbg {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .42);
      z-index: 200;
      align-items: center;
      justify-content: center;
    }

    .mbg.open {
      display: flex;
    }

    .mcard {
      background: #fdf9f6;
      border-radius: 24px;
      padding: 40px;
      max-width: 480px;
      width: 92%;
      position: relative;
      border: 1px solid #f0e8df;
      max-height: 88vh;
      overflow-y: auto;
    }

    .mclose {
      position: absolute;
      top: 16px;
      right: 18px;
      background: none;
      border: none;
      font-size: 20px;
      cursor: pointer;
      color: #bbb;
    }

    .mname {
      font-size: 28px;
      font-weight: 900;
      color: #1a1a1a;
      letter-spacing: -1px;
      margin-bottom: 2px;
    }

    .mrole {
      font-family: 'Caveat', cursive;
      font-size: 17px;
      color: #e8587a;
      margin-bottom: 18px;
    }

    .msec {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #bbb;
      margin: 18px 0 10px;
    }

    .mexp {
      margin-bottom: 12px;
      padding-bottom: 12px;
      border-bottom: 1px solid #f5ede8;
    }

    .mexp:last-child {
      border-bottom: none;
    }

    .mexp-title {
      font-size: 13px;
      font-weight: 700;
      color: #1a1a1a;
    }

    .mexp-org {
      font-size: 12px;
      color: #e8587a;
      margin-top: 1px;
    }

    .mexp-date {
      font-size: 11px;
      color: #bbb;
      margin-top: 1px;
    }

    .mexp-desc {
      font-size: 12px;
      color: #666;
      line-height: 1.6;
      margin-top: 5px;
    }

    .mtags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 10px;
    }

    .mtag {
      background: #fce7f3;
      color: #9d174d;
      border-radius: 50px;
      padding: 4px 12px;
      font-size: 11px;
      font-weight: 500;
    }

    .mtag-blue {
      background: #dbeafe;
      color: #1e40af;
    }

    .mlink {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
      background: #f5f0ea;
      border-radius: 50px;
      padding: 8px 16px;
      font-size: 12px;
      font-weight: 600;
      color: #1a1a1a;
      margin-top: 8px;
      margin-right: 8px;
      transition: background .2s;
      border: 1px solid rgba(180, 165, 150, 0.2);
    }

    .mlink:hover {
      background: #ede8e0;
    }
  </style>
</head>

